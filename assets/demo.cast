[0.782832, "o", "\u001b[1;36mSpecify\u001b[0m \u001b[2m—\u001b[0m spec-driven functional verification\r\n\r\n\u001b[1mUsage:\u001b[0m specify \u001b[36m<noun>\u001b[0m \u001b[36m<verb>\u001b[0m \u001b[2m[options]\u001b[0m\r\n\r\n\u001b[1mCommands:\u001b[0m\r\n  \u001b[36mspec validate\u001b[0m    Validate a spec against captured data\r\n  \u001b[36mspec generate\u001b[0m    Generate a spec from capture data\r\n  \u001b[36mspec refine\u001b[0m      Refine a spec interactively or using a gap report\r\n  \u001b[36mspec evolve\u001b[0m      Evolve a spec from PR changes or interactively\r\n  \u001b[36mspec import\u001b[0m      Import existing e2e tests as spec items\r\n  \u001b[36mspec export\u001b[0m      Export spec items as e2e test code\r\n  \u001b[36mspec sync\u001b[0m        Compare spec against e2e tests bidirectionally\r\n  \u001b[36mspec lint\u001b[0m        Validate spec structure \u001b[2m(no captures needed)\u001b[0m\r\n  \u001b[36mspec guide\u001b[0m       Output authoring guide for LLM spec writers\r\n  \u001b[36magent run\u001b[0m        Run autonomous agent-driven verification\r\n  \u001b[36mcli run\u001b[0m          Run CLI verification against a spec\r\n  \u001b[36mreport diff\u001b[0m      Diff two gap reports\r\n  \u001b[36mreport stats\u001b[0m     Show statistical confidence from history\r\n  \u001b[36mschema\u001b[0m           Output JSON Schema \u001b[2m(spec, report, or commands)\u001b[0m\r\n  \u001b[36mmcp\u001b[0m              Start MCP server for LLM tool integration\r\n  \u001b[36mhuman\u001b[0m            Interactive mode \u001b[2m(wizard, REPL, TUI)\u001b[0m\r\n\r\n"]
