#!/usr/bin/env bash
# specify — CLI entry point
#
# Auto-builds TypeScript if needed, then runs the CLI.
#
#   ./specify --help
#   ./specify spec validate --spec spec.yaml --capture ./captures
#   ./specify cli run --spec spec.yaml
#   ./specify human

set -euo pipefail

# Resolve symlinks — works on both macOS and Linux
resolve_path() {
  local target="$1"
  while [ -L "$target" ]; do
    local dir; dir="$(cd "$(dirname "$target")" && pwd)"
    target="$(readlink "$target")"
    [[ "$target" != /* ]] && target="$dir/$target"
  done
  echo "$(cd "$(dirname "$target")" && pwd)"
}

SCRIPT_DIR="$(resolve_path "${BASH_SOURCE[0]}")"
DIST="$SCRIPT_DIR/dist/src/cli/index.js"

# Auto-install if node_modules is missing or incomplete
if [ ! -d "$SCRIPT_DIR/node_modules/typescript" ]; then
  echo "Installing dependencies..." >&2
  npm install --prefix "$SCRIPT_DIR" --ignore-scripts 2>&1 | grep -v '^$' >&2
fi

# Auto-build if dist is missing or any source file is newer
needs_build() {
  [ ! -f "$DIST" ] && return 0
  local newer
  newer=$(find "$SCRIPT_DIR/src" -name '*.ts' -newer "$DIST" -print -quit 2>/dev/null)
  [ -n "$newer" ]
}

if needs_build; then
  echo "Building TypeScript..." >&2
  # Use specify's own tsc, not whatever the caller's cwd resolves to.
  # `npx tsc` from another project picks up the registry placeholder
  # package whose only output is "this is not the tsc you are looking for".
  "$SCRIPT_DIR/node_modules/.bin/tsc" --project "$SCRIPT_DIR/tsconfig.json"
fi

exec node "$DIST" "$@"
