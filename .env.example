# ─── Specify — environment configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables are optional unless marked REQUIRED.

# ─── Target application ───────────────────────────────────────────────────────

# [REQUIRED] Base URL of the application under test
TARGET_BASE_URL=https://app.example.com

# Login URL (defaults to TARGET_BASE_URL if not set)
TARGET_LOGIN_URL=https://app.example.com/login

# Comma-separated list of hostname substrings to capture traffic for
# Default: derived from TARGET_BASE_URL hostname
CAPTURE_HOST_FILTER=example.com

# ─── Auth / session capture (scripts/login.ts) ───────────────────────────────

# CSS selector for the username/email input field
AUTH_USERNAME_SELECTOR=#username

# CSS selector for the password input field
AUTH_PASSWORD_SELECTOR=#password

# CSS selector for the submit/login button
AUTH_SUBMIT_SELECTOR=button[type=submit]

# Comma-separated cookie names to look for and report after login
# Used to confirm successful auth
AUTH_COOKIE_NAMES=session,token,auth

# Path to store captured auth state (default: .auth/)
AUTH_DIR=.auth

# ─── Browse & capture (scripts/browse-and-capture.mjs) ───────────────────────

# Output directory for captured traffic (default: captures/)
CAPTURE_OUTPUT_DIR=captures

# Milliseconds to wait after API responses before taking screenshot (default: 800)
CAPTURE_SCREENSHOT_DELAY_MS=800

# ─── CDP capture (scripts/cdp-capture.ts) ────────────────────────────────────

# Chrome DevTools Protocol debugging host (default: localhost)
CDP_HOST=localhost

# Chrome DevTools Protocol debugging port (default: 9222)
CDP_PORT=9222

# Maximum response body size to capture in bytes (default: 1048576 = 1 MB)
CDP_MAX_BODY_BYTES=1048576

# ─── API discovery (scripts/api-discover.ts) ─────────────────────────────────

# Path to stored Playwright session state (from login.ts)
# Default: .auth/storage-state.json
STORAGE_STATE_PATH=.auth/storage-state.json

# Delay in milliseconds between requests during discovery (default: 600)
DISCOVER_DELAY_MS=600

# Output directory for discovery reports (default: docs/)
DISCOVER_OUTPUT_DIR=docs

# Comma-separated list of page paths to visit during discovery
# Example: /dashboard,/profile,/settings
DISCOVER_PAGES=/dashboard,/settings,/profile

# ─── Live discovery (scripts/live-discover.ts) ───────────────────────────────

# Same as DISCOVER_PAGES — list of page paths to visit and capture traffic
LIVE_DISCOVER_PAGES=/dashboard,/settings,/profile

# ─── Live discovery fetch (scripts/live-discover-fetch.ts) ───────────────────

# Same settings as live-discover.ts but uses Node.js native fetch (no browser)
# Requires STORAGE_STATE_PATH to be set above

# ─── Mock server (src/mock-server.ts) ────────────────────────────────────────

# Port to run the mock server on (default: 3456)
PORT=3456

# Path to captured traffic file to replay (default: searches captures/ dir)
MOCK_DATA_PATH=captures/traffic.json

# Session cookie name to issue (default: session)
MOCK_SESSION_COOKIE_NAME=session

# Secondary/framework session cookie name (default: empty — disabled)
MOCK_SESSION_COOKIE_2_NAME=

# Session TTL in milliseconds (default: 600000 = 10 minutes)
MOCK_SESSION_TTL_MS=600000

# Fault injection rate — 0 to disable, 0.1 = 10% of requests (default: 0)
MOCK_FAULT_RATE=0

# Comma-separated fault types to enable when fault injection is active
# Valid values: 302, 500, timeout, empty, malformed
# Default: all types enabled
MOCK_FAULT_TYPES=302,500,timeout,empty,malformed

# Path of the login page for auth redirects (default: /login)
MOCK_LOGIN_PATH=/login

# Path to redirect to after successful login (default: /)
MOCK_POST_LOGIN_REDIRECT=/

# Cookie refresh path — a GET to this path extends the session and sets cookies
# Default: /auth/refresh (set to empty to disable)
MOCK_REFRESH_PATH=/auth/refresh
