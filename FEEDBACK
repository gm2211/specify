version: "1.0"
name: "Building Updates Admin Dashboard"
description: >
  Functional spec for the Building Updates lobby display admin application.
  The app is a building management dashboard that allows admins to manage
  services (HVAC, elevators, etc.), events, advisories, and user accounts.
  Changes go through a draft/publish workflow with version history and
  rollback support. A public-facing dashboard displays the published state
  with auto-scrolling cards. SSE provides real-time push updates.

narrative_path: spec.narrative.md

variables:
  BASE_URL: "${BASE_URL:-https://seven7-hudson-staging.onrender.com}"
  ADMIN_USER: "${E2E_ADMIN_USER:-admin-staging}"
  ADMIN_PASS: "${E2E_ADMIN_PASS}"

assumptions:
  - type: url_reachable
    url: "{{BASE_URL}}/api/health"
    description: "Application is running and healthy"
  - type: api_returns
    url: "{{BASE_URL}}/api/health"
    status: 200
    description: "Health endpoint returns 200"

defaults:
  no_5xx: true
  no_console_errors: true
  no_uncaught_exceptions: true
  page_load_timeout_ms: 15000

# ---------------------------------------------------------------------------
# Pages
# ---------------------------------------------------------------------------

pages:
  # --- Login Page ---
  - id: login
    path: /login
    title: "Building Updates"
    visual_assertions:
      - type: text_contains
        selector: "h2, h1"
        text: "Sign In"
        description: "Login page shows Sign In heading"
      - type: element_exists
        selector: "input[type='text']"
        description: "Username input field exists"
      - type: element_exists
        selector: "input[type='password']"
        description: "Password input field exists"
      - type: element_exists
        selector: "button[type='submit']"
        description: "Submit button exists"
    scenarios:
      - id: login-invalid-credentials
        description: "Attempting login with invalid credentials shows an error"
        steps:
          - action: fill
            selector: "input[type='text']"
            value: "baduser"
          - action: fill
            selector: "input[type='password']"
            value: "badpass"
          - action: click
            selector: "button[type='submit']"
          - action: wait
            duration: 2000
          - action: assert_visible
            selector: "[class*='error'], [class*='Error'], [role='alert']"
            description: "Error message is displayed for invalid credentials"

      - id: login-success
        description: "Logging in with valid credentials redirects to /admin"
        steps:
          - action: fill
            selector: "input[type='text']"
            value: "{{ADMIN_USER}}"
          - action: fill
            selector: "input[type='password']"
            value: "{{ADMIN_PASS}}"
          - action: click
            selector: "button[type='submit']"
          - action: wait_for_navigation
            url_pattern: "/admin"
            description: "Redirects to admin page after successful login"

  # --- Admin Dashboard ---
  - id: admin
    path: /admin
    title: "Building Updates"
    visual_assertions:
      - type: text_contains
        selector: "h1"
        text: "Admin"
        description: "Admin page heading contains 'Admin'"
      - type: element_exists
        selector: "button"
        description: "Action buttons exist (Publish, Discard, Preview, History)"

      # Dashboard Config section
      - type: text_contains
        selector: "h2"
        text: "Dashboard Config"
        description: "Dashboard Config section exists"
      - type: element_exists
        selector: "input"
        description: "Dashboard title input exists"

      # Services section
      - type: text_contains
        selector: "h2"
        text: "Services"
        description: "Services section exists"
      - type: element_exists
        selector: "button"
        description: "Add Service button exists"
        confidence: observed
      - type: element_count
        selector: "select"
        min: 1
        description: "At least one status dropdown exists for services"

      # Events section
      - type: text_contains
        selector: "h2"
        text: "Events"
        description: "Events section exists"

      # Advisories section
      - type: text_contains
        selector: "h2"
        text: "Advisories"
        description: "Advisories section exists"

      # Users section
      - type: text_contains
        selector: "h2"
        text: "Users"
        description: "Users management section exists"
      - type: element_exists
        selector: "table"
        description: "Users table exists"

    expected_requests:
      - method: GET
        url_pattern: "/api/services"
        description: "Loads services list"
        response:
          status: 200
          content_type: "application/json"
          body_schema:
            type: array
            items:
              type: object
              required: ["id", "name", "status"]
              properties:
                id:
                  type: number
                name:
                  type: string
                status:
                  type: string
                  enum: ["Operational", "Maintenance", "Outage"]
                notes:
                  type: string
                sortOrder:
                  type: number
                markedForDeletion:
                  type: boolean

      - method: GET
        url_pattern: "/api/events"
        description: "Loads events list"
        response:
          status: 200
          content_type: "application/json"
          body_schema:
            type: array
            items:
              type: object
              required: ["id", "title"]
              properties:
                id:
                  type: number
                title:
                  type: string
                subtitle:
                  type: string
                details:
                  type: array
                  items:
                    type: string
                imageUrl:
                  type: string
                accentColor:
                  type: string
                sortOrder:
                  type: number

      - method: GET
        url_pattern: "/api/advisories"
        description: "Loads advisories list"
        response:
          status: 200
          content_type: "application/json"
          body_schema:
            type: array
            items:
              type: object
              required: ["id", "message"]
              properties:
                id:
                  type: number
                message:
                  type: string
                active:
                  type: boolean

      - method: GET
        url_pattern: "/api/users"
        description: "Loads users list"
        response:
          status: 200
          content_type: "application/json"
          body_schema:
            type: array
            items:
              type: object
              required: ["id", "username", "role"]
              properties:
                id:
                  type: number
                username:
                  type: string
                role:
                  type: string
                  enum: ["ADMIN", "EDITOR", "VIEWER"]

      - method: GET
        url_pattern: "/api/config"
        description: "Loads dashboard configuration"
        response:
          status: 200
          content_type: "application/json"
          body_schema:
            type: object
            required: ["dashboardTitle"]
            properties:
              dashboardTitle:
                type: string
              scrollSpeed:
                type: number
              tickerSpeed:
                type: number
              servicesScrollSpeed:
                type: number
              servicesFontSize:
                type: number
              notesFontSize:
                type: number
              notesFontWeight:
                type: number

      - method: GET
        url_pattern: "/api/snapshots"
        description: "Loads version history"
        response:
          status: 200
          content_type: "application/json"
          body_schema:
            type: array
            items:
              type: object
              required: ["id", "version", "publishedAt"]
              properties:
                id:
                  type: number
                version:
                  type: number
                publishedAt:
                  type: string
                publishedBy:
                  type: string

    scenarios:
      - id: admin-top-bar-buttons
        description: "Admin top bar has Publish, Discard, Preview, History, Metrics, and Logout"
        steps:
          - action: assert_visible
            selector: "button"
            description: "Publish button exists"
          - action: assert_text
            selector: "a[href='/metrics']"
            text: "Metrics"
            description: "Metrics link exists"
          - action: assert_text
            selector: "a[href='/']"
            text: "Dashboard"
            description: "Dashboard link exists"

      - id: admin-version-history
        description: "Clicking History opens a version history modal"
        steps:
          - action: click
            selector: "button:has-text('History')"
            description: "Click History button"
          - action: wait
            duration: 1000
          - action: assert_visible
            selector: "[class*='modal'], [class*='Modal'], [role='dialog']"
            description: "History modal/dialog appears"
          - action: assert_text
            selector: "h2, h3"
            text: "Version History"
            description: "Modal title says Version History"

  # --- Public Dashboard ---
  - id: dashboard
    path: /
    title: "Building Updates"
    visual_assertions:
      - type: element_exists
        selector: "h1, [class*='title'], [class*='Title']"
        description: "Dashboard title is visible"
      - type: element_exists
        selector: "table, [class*='service'], [class*='Service']"
        description: "Services table/list is displayed"
        confidence: observed
    expected_requests:
      - method: GET
        url_pattern: "/api/services"
        description: "Dashboard loads published services"
        response:
          status: 200
      - method: GET
        url_pattern: "/api/events"
        description: "Dashboard loads published events"
        response:
          status: 200
      - method: GET
        url_pattern: "/api/advisories"
        description: "Dashboard loads published advisories"
        response:
          status: 200
      - method: GET
        url_pattern: "/api/config"
        description: "Dashboard loads display configuration"
        response:
          status: 200

  # --- Preview Mode ---
  - id: dashboard-preview
    path: /?preview=true
    title: "Building Updates"
    visual_assertions:
      - type: element_exists
        selector: "body"
        description: "Preview mode renders the dashboard with draft content"
        confidence: inferred

  # --- Metrics Page ---
  - id: metrics
    path: /metrics
    visual_assertions:
      - type: text_contains
        selector: "h1, h2"
        text: "Service Metrics"
        description: "Metrics page heading"
      - type: text_contains
        selector: "h2, h3"
        text: "Trend Insights"
        description: "Trend Insights section"
      - type: text_contains
        selector: "h2, h3"
        text: "Response Time Percentiles"
        description: "Response Time Percentiles section"
      - type: text_contains
        selector: "h2, h3, h4"
        text: "By Service"
        description: "By Service breakdown section"
      - type: text_contains
        selector: "h2, h3"
        text: "Status Timeline"
        description: "Status Timeline section"
      - type: element_exists
        selector: "button"
        description: "Time range buttons exist (24h, 7d, 30d)"
        confidence: observed
    scenarios:
      - id: metrics-time-range
        description: "Time range buttons filter metrics data"
        steps:
          - action: assert_text
            selector: "button"
            text: "24h"
            description: "24h button exists"
          - action: assert_text
            selector: "button"
            text: "7d"
            description: "7d button exists"
          - action: assert_text
            selector: "button"
            text: "30d"
            description: "30d button exists"

# ---------------------------------------------------------------------------
# Flows
# ---------------------------------------------------------------------------

flows:
  - id: login-to-admin
    description: "User logs in and reaches the admin dashboard"
    steps:
      - navigate: "{{BASE_URL}}/login"
        description: "Go to login page"
      - assert_page: login
        description: "Verify login page structure"
      - action: fill
        selector: "input[type='text']"
        value: "{{ADMIN_USER}}"
      - action: fill
        selector: "input[type='password']"
        value: "{{ADMIN_PASS}}"
      - action: click
        selector: "button[type='submit']"
      - action: wait_for_navigation
        url_pattern: "/admin"
      - assert_page: admin
        description: "Verify admin dashboard loads correctly"

  - id: unauthenticated-redirect
    description: "Unauthenticated user hitting /admin gets redirected to /login"
    steps:
      - navigate: "{{BASE_URL}}/admin"
        description: "Try to access admin without auth"
      - action: wait_for_navigation
        url_pattern: "/login"
        description: "Should redirect to login page"
      - assert_page: login

  - id: admin-to-metrics
    description: "Navigate from admin to metrics page"
    steps:
      - navigate: "{{BASE_URL}}/admin"
      - action: fill
        selector: "input[type='text']"
        value: "{{ADMIN_USER}}"
      - action: fill
        selector: "input[type='password']"
        value: "{{ADMIN_PASS}}"
      - action: click
        selector: "button[type='submit']"
      - action: wait_for_navigation
        url_pattern: "/admin"
      - action: click
        selector: "a[href='/metrics']"
        description: "Click Metrics link"
      - action: wait_for_navigation
        url_pattern: "/metrics"
      - assert_page: metrics

# ---------------------------------------------------------------------------
# Behavioral Requirements (agent-verified)
# ---------------------------------------------------------------------------

requirements:
  - id: draft-publish-workflow
    description: >
      Changes made in the admin panel are not immediately visible on the public
      dashboard. They exist as a draft until explicitly published via the Publish
      button. The Preview button shows draft content. Discard reverts to last
      published state.
    verification: agent
    validation_plan: |
      1. Log in to admin and note the current dashboard title
      2. Change the dashboard title to a unique test value
      3. Check the public dashboard — it should NOT show the new title
      4. Check /?preview=true — it SHOULD show the new title
      5. Click Publish in admin
      6. Check the public dashboard — it should NOW show the new title
      7. Restore the original title and publish again
    evidence_format: "Screenshots or API responses showing title before/after publish"

  - id: version-history-rollback
    description: >
      Every publish creates a versioned snapshot. The Version History dialog shows
      all past versions with timestamps and publisher. Users can restore a previous
      version.
    verification: agent
    validation_plan: |
      1. GET /api/snapshots and verify it returns a list of versions
      2. Verify each snapshot has id, version, publishedAt, publishedBy
      3. Open Version History dialog in admin
      4. Verify it shows version entries with dates and publisher names
      5. Check that "Page Differences" button exists for comparing versions

  - id: role-based-access-control
    description: >
      GET requests to API endpoints require authentication but any role.
      Mutations (POST/PUT/DELETE) require EDITOR or ADMIN role. VIEWER role
      cannot make changes.
    verification: agent
    validation_plan: |
      1. Without auth, GET /api/services should redirect or return 401
      2. As ADMIN, POST to create a test service — should succeed
      3. As VIEWER (if available), POST to create a service — should be denied
      4. Clean up test data

  - id: csrf-protection
    description: >
      All state-changing /api/* requests require a CSRF token. Requests without
      a valid CSRF token should be rejected.
    verification: agent
    validation_plan: |
      1. Authenticate and obtain a session
      2. Attempt a POST/PUT/DELETE without CSRF token — should fail
      3. Attempt same request with valid CSRF token — should succeed

  - id: sse-real-time-updates
    description: >
      Publishing changes triggers real-time push via Server-Sent Events (SSE).
      Connected dashboard clients receive updates without polling.
    verification: agent
    validation_plan: |
      1. Open an SSE connection to the appropriate endpoint
      2. Publish a change in admin
      3. Verify the SSE connection receives an update event
    evidence_format: "SSE event data received after publish"

  - id: service-status-management
    description: >
      Services have three statuses: Operational, Maintenance, and Outage.
      Each service has a name, status dropdown, notes field, and delete button.
      Services can be added, reordered, and removed (soft-deleted via markedForDeletion).
    verification: agent
    validation_plan: |
      1. Verify service list loads with correct fields
      2. Check status dropdown has exactly three options: Operational, Maintenance, Outage
      3. Verify add service button creates a new service entry
      4. Verify delete (✕) marks service for deletion (markedForDeletion, not hard delete)

  - id: events-crud
    description: >
      Events have title, subtitle, details (string array), imageUrl, and accentColor.
      Events can be created, edited (✎), cloned (⧉), previewed, and deleted (✕).
    verification: agent
    validation_plan: |
      1. Check events section shows existing events with images
      2. Click Add New Event and verify a form appears
      3. Click edit (✎) on an existing event and verify editing works
      4. Click clone (⧉) and verify it creates a duplicate
      5. Clean up any test data

  - id: advisories-crud
    description: >
      Advisories are short text messages displayed as a ticker on the public
      dashboard. They can be created, edited, cloned, and deleted.
    verification: agent
    validation_plan: |
      1. Check advisories section shows existing advisories
      2. Click Add New Advisory and verify a form appears
      3. Verify scroll speed controls exist

  - id: user-management
    description: >
      Admin users can manage other users. The Users section shows a table of
      usernames and roles. New users can be added with username, password, and
      role (ADMIN, EDITOR, or VIEWER).
    verification: agent
    validation_plan: |
      1. Verify users table shows current user with correct role
      2. Check add user form has username, password fields and role selector
      3. Verify role dropdown has ADMIN, EDITOR, VIEWER options

  - id: auto-scrolling-dashboard
    description: >
      The public dashboard uses auto-scrolling cards for services, events, and
      advisories. Scroll speed is configurable via admin settings.
    verification: agent
    validation_plan: |
      1. Load the public dashboard
      2. Check for auto-scrolling behavior on service cards
      3. Verify scrollSpeed, tickerSpeed, servicesScrollSpeed config values exist in /api/config

  - id: dashboard-config-persistence
    description: >
      Dashboard configuration (title, scroll speeds, font sizes) persists across
      sessions and is served via /api/config.
    verification: agent
    validation_plan: |
      1. GET /api/config and verify all expected fields exist
      2. Verify dashboardTitle, scrollSpeed, tickerSpeed, servicesScrollSpeed,
         servicesFontSize, notesFontSize, notesFontWeight are present
      3. Change a value in admin, publish, and verify /api/config reflects the change

