{
  "name": "specify",
  "version": "0.1.0",
  "description": "Web capture toolkit for spec-based functional verification",
  "type": "module",
  "scripts": {
    "login": "PLAYWRIGHT_BROWSERS_PATH=0 npx tsx scripts/login.ts",
    "browse": "node scripts/browse-and-capture.mjs",
    "capture": "npx tsx scripts/cdp-capture.ts",
    "discover": "npx tsx scripts/api-discover.ts",
    "live-discover": "npx tsx scripts/live-discover.ts",
    "live-discover-fetch": "npx tsx scripts/live-discover-fetch.ts",
    "mock": "npx tsx src/mock-server.ts",
    "mock:chaos": "MOCK_FAULT_RATE=0.1 npx tsx src/mock-server.ts",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.2",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
