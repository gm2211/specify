{
  "name": "specify",
  "version": "0.1.1",
  "description": "Web capture toolkit for spec-based functional verification",
  "type": "module",
  "bin": {
    "specify": "dist/src/cli/index.js"
  },
  "scripts": {
    "login": "PLAYWRIGHT_BROWSERS_PATH=0 npx tsx scripts/login.ts",
    "browse": "node scripts/browse-and-capture.mjs",
    "capture": "npx tsx scripts/cdp-capture.ts",
    "discover": "npx tsx scripts/api-discover.ts",
    "live-discover": "npx tsx scripts/live-discover.ts",
    "live-discover-fetch": "npx tsx scripts/live-discover-fetch.ts",
    "mock": "npx tsx src/mock-server.ts",
    "mock:chaos": "MOCK_FAULT_RATE=0.1 npx tsx src/mock-server.ts",
    "generate-spec": "npx tsx src/spec/generator.ts",
    "typecheck": "npx tsc --noEmit",
    "validate": "npx tsx src/validation/validate.ts",
    "agent": "npx tsx src/cli/index.ts capture",
    "test": "tsc && node --test dist/src/**/*.test.js",
    "build": "tsc",
    "specify": "npx tsx src/cli/index.ts",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/ws": "^8.18.1",
    "ajv": "^8.18.0",
    "chrome-remote-interface": "^0.33.2",
    "hono": "^4.12.9",
    "js-yaml": "^4.1.1",
    "playwright": "^1.50.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
