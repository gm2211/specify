#!/usr/bin/env node
/**
 * .bin/specify-cli — Argos specify-cli contract implementation for the specify repo.
 *
 * Backing store: .beads/issues.jsonl (open issues → flagged items)
 * Addressed tracking: .specify/addressed-items.jsonl (local, gitignored via .specify/)
 *
 * Implements: status, list-flagged, mark-addressed, verify, activity, open, flag
 * Exit codes: 0=ok, 1=usage/bad-args, 2=auth, 3=daemon-unreachable, 4=not-found
 */

import { readFileSync, writeFileSync, appendFileSync, existsSync, mkdirSync } from 'node:fs';
import { resolve, dirname } from 'node:path';
import { fileURLToPath } from 'node:url';

const __dirname = dirname(fileURLToPath(import.meta.url));
const REPO_ROOT = resolve(__dirname, '..');

// Store paths
const BEADS_FILE = resolve(REPO_ROOT, '.beads/issues.jsonl');
const SPECIFY_DIR = resolve(REPO_ROOT, '.specify');
const ADDRESSED_FILE = resolve(SPECIFY_DIR, 'addressed-items.jsonl');
const ACTIVITY_FILE = resolve(SPECIFY_DIR, 'activity-log.jsonl');
const SPEC_PATH = resolve(REPO_ROOT, 'specify.spec.yaml');

// ── helpers ──────────────────────────────────────────────────────────────────

function parseArgs(argv) {
  const flags = {};
  for (const arg of argv) {
    if (arg.startsWith('--')) {
      const eq = arg.indexOf('=');
      if (eq !== -1) {
        flags[arg.slice(2, eq)] = arg.slice(eq + 1);
      } else {
        flags[arg.slice(2)] = true;
      }
    }
  }
  return flags;
}

function die(msg, code = 1) {
  process.stderr.write(msg + '\n');
  process.exit(code);
}

function out(obj) {
  process.stdout.write(JSON.stringify(obj) + '\n');
}

function loadBeadsItems() {
  if (!existsSync(BEADS_FILE)) return [];
  return readFileSync(BEADS_FILE, 'utf8')
    .split('\n')
    .filter(Boolean)
    .map(l => JSON.parse(l));
}

function loadAddressed() {
  if (!existsSync(ADDRESSED_FILE)) return new Set();
  return new Set(
    readFileSync(ADDRESSED_FILE, 'utf8')
      .split('\n')
      .filter(Boolean)
      .map(l => JSON.parse(l).id)
  );
}

function ensureSpecifyDir() {
  if (!existsSync(SPECIFY_DIR)) mkdirSync(SPECIFY_DIR, { recursive: true });
}

function appendActivity(kind, ref, summary) {
  ensureSpecifyDir();
  const entry = { ts: new Date().toISOString(), kind, ref, summary };
  appendFileSync(ACTIVITY_FILE, JSON.stringify(entry) + '\n');
}

function issueTypeToKind(issueType) {
  if (issueType === 'bug') return 'regression';
  if (issueType === 'feature') return 'spec-drift';
  if (issueType === 'task') return 'spec-drift';
  return 'spec-drift';
}

function issueToFlaggedItem(issue) {
  return {
    id: issue.id,
    title: issue.title,
    evidence: issue.description || '(no description)',
    kind: issueTypeToKind(issue.issue_type),
    createdAt: issue.created_at,
  };
}

// ── subcommands ───────────────────────────────────────────────────────────────

function cmdStatus() {
  const running = existsSync(SPEC_PATH);
  out({
    running,
    mode: 'local',
    specPath: SPEC_PATH,
    lastVerifyAt: existsSync(resolve(SPECIFY_DIR, 'verify/verify-result.json'))
      ? readFileSync(resolve(SPECIFY_DIR, 'verify/verify-result.json'), 'utf8')
          .match(/"updatedAt"\s*:\s*"([^"]+)"/)
          ?.[1] ?? null
      : null,
  });
}

function cmdListFlagged(flags) {
  const limit = flags.limit ? parseInt(flags.limit, 10) : 50;
  const since = flags.since || null;

  const addressed = loadAddressed();
  let items = loadBeadsItems()
    .filter(i => i._type === 'issue' && i.status === 'open')
    .filter(i => !addressed.has(i.id))
    .map(issueToFlaggedItem);

  // Cursor-based pagination (cursor = last id seen)
  if (since) {
    const idx = items.findIndex(i => i.id === since);
    if (idx !== -1) items = items.slice(idx + 1);
  }

  const page = items.slice(0, limit);
  const cursor = page.length >= limit && items.length > limit ? page[page.length - 1].id : '';

  out({ items: page, cursor });
}

function cmdMarkAddressed(flags) {
  const id = flags.id;
  if (!id) die('missing --id', 1);

  ensureSpecifyDir();

  // Verify item exists
  const addressed = loadAddressed();
  if (addressed.has(id)) {
    // Already addressed — idempotent success
    process.exit(0);
  }

  const allItems = loadBeadsItems();
  const found = allItems.find(i => i.id === id);
  if (!found) {
    // Check if it was ever an open issue
    die(`item not found: ${id}`, 4);
  }

  appendFileSync(ADDRESSED_FILE, JSON.stringify({ id, addressedAt: new Date().toISOString() }) + '\n');
  appendActivity('addressed', id, `Addressed: ${found.title}`);
  process.exit(0);
}

function cmdVerify(flags) {
  const verifyResultPath = resolve(SPECIFY_DIR, 'verify/verify-result.json');
  if (!existsSync(verifyResultPath)) {
    out({ verified: true, missingMarkers: [] });
    return;
  }
  try {
    const result = JSON.parse(readFileSync(verifyResultPath, 'utf8'));
    const so = result.structuredOutput || {};
    const failed = (so.results || []).filter(r => r.status === 'failed');
    out({
      verified: so.pass === true,
      missingMarkers: failed.map(r => ({
        section: r.id.split('/')[0] || r.id,
        expectedMarker: r.id,
      })),
    });
  } catch {
    out({ verified: false, missingMarkers: [] });
  }
}

function cmdActivity(flags) {
  const since = flags.since ? new Date(flags.since) : new Date(Date.now() - 86400000);
  const events = [];

  if (existsSync(ACTIVITY_FILE)) {
    for (const line of readFileSync(ACTIVITY_FILE, 'utf8').split('\n').filter(Boolean)) {
      try {
        const e = JSON.parse(line);
        if (new Date(e.ts) >= since) events.push(e);
      } catch {}
    }
  }

  out(events);
}

function cmdOpen(flags) {
  const id = flags.id;
  if (id) {
    process.stdout.write(`https://github.com/gm2211/specify/issues/${id}\n`);
  } else {
    process.stdout.write(`${SPEC_PATH}\n`);
  }
  process.exit(0);
}

function cmdFlag(flags) {
  const beadId = flags['bead-id'];
  const note = flags.note;
  if (!beadId) die('missing --bead-id', 1);
  if (!note) die('missing --note', 1);

  ensureSpecifyDir();
  appendActivity('flag', beadId, `Flagged by bead ${beadId}: ${note}`);
  process.exit(0);
}

// ── main ──────────────────────────────────────────────────────────────────────

const [, , subcmd, ...rest] = process.argv;
const flags = parseArgs(rest);

switch (subcmd) {
  case 'status':
    cmdStatus();
    break;
  case 'list-flagged':
    cmdListFlagged(flags);
    break;
  case 'mark-addressed':
    cmdMarkAddressed(flags);
    break;
  case 'verify':
    cmdVerify(flags);
    break;
  case 'activity':
    cmdActivity(flags);
    break;
  case 'open':
    cmdOpen(flags);
    break;
  case 'flag':
    cmdFlag(flags);
    break;
  default:
    die(
      `Usage: specify-cli <subcommand> [flags]\n` +
        `Subcommands: status, list-flagged, mark-addressed, verify, activity, open, flag`,
      1
    );
}
